# Copy to .streamlit/secrets.toml for LOCAL use (never commit the real file).
# On Streamlit Community Cloud, paste these into App -> Settings -> Secrets instead.

# Required for the 'jsearch' source (LinkedIn/Indeed/Glassdoor/Naukri via Google for Jobs).
RAPIDAPI_KEY = "your-rapidapi-key"

# Required ONLY for the "Generate ATS resume" button (one cheap call per click).
ANTHROPIC_API_KEY = "your-anthropic-key"
# ANTHROPIC_MODEL = "claude-sonnet-4-6"   # optional override

# Pick ONE alert channel:
SLACK_WEBHOOK_URL = "https://hooks.slack.com/services/XXX/YYY/ZZZ"
# TELEGRAM_BOT_TOKEN = "123456:ABC..."
# TELEGRAM_CHAT_ID   = "987654321"
